[Pushover]
AppToken=your-pushover-app-token
UserKey=your-pushover-user-key
Device=
Title=Screen match detected
Priority=0

[Detection]
ImagePath=sample.png
ImageLabel=sample.png
SearchRegion=full
Variation=30
Scales=0.85,0.95,1.00,1.10,1.20
ScanIntervalMs=500
ConfirmRadiusPx=20
RequireConfirmations=2
ClearAfterMisses=3
CooldownMs=30000

[Action]
ClickOnMatch=0
ClickDelayMs=150
MoveMouseFirst=0

[Hotkeys]
PauseToggle=F8
ManualScan=F9

[Debug]
LogToFile=1
